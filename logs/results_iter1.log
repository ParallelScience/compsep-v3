    print('Global Pixel Correlation (Standard MWF):    ' + str(round(corr_std, 4)))
    print('Mean T(ell) [ell < 3000] (Constrained MWF): ' + str(round(np.mean(T_ell_constrained[ell < 3000]), 4)))
