    plt.figure(figsize=(8, 6))
    plt.plot(ell_val[1:], cl_val_mean[1:], label='Empirical C_ell (White Noise)', color='blue')
    plt.axhline(theory_cl, color='red', linestyle='--', label='Theoretical C_ell')
