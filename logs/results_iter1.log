        sigma_vals = np.full_like(y_vals, sigma_noise)
        bc_vals = apply_lookup_array(y_vals, sigma_vals, cib_vals)
        bc_int_Y = np.sum(bc_vals)
        results.append((mass_proxy, true_int_Y, raw_int_Y, bc_int_Y))
    return results
