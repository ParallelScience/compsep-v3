def compute_standard_tf(args):
    y_pred_std, tsz_true = args
    _, cl_pred_true = utils.powers(y_pred_std, tsz_true, ps=5, window_alpha=0.5)
    return cl_pred_true

if __name__ == '__main__':
    os.environ['OMP_NUM_THREADS'] = '16'
