    plt.axhline(1.0, color='black', linestyle=':', alpha=0.7)
    plt.xlabel('Multipole ell')
    plt.ylabel('Transfer Function T(ell)')
    plt.title('Spatial Fidelity Benchmark: Transfer Function')
    plt.xscale('log')
