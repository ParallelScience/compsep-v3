    axs[0, 1].legend()
    axs[0, 1].grid(True, which='both', ls='--', alpha=0.5)
    snr_centers = (snr_bins[:-1] + snr_bins[1:]) / 2
    axs[1, 0].plot(snr_centers, pur_snr_std, label='Standard ILC', marker='o')
